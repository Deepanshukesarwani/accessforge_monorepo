generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Better Auth manages the `user`, `session`, `account`, `verification`,
// `organization`, `member`, and `invitation` collections directly via
// its MongoDB adapter. Do NOT add a Prisma user model — it would write
// to the same collection and corrupt Better Auth's data.
//
// Task.assignedToId and Task.createdById store Better Auth user IDs
// (plain strings generated by Better Auth, not MongoDB ObjectIds).

enum TaskStatus {
  Active
  InProgress
  Completed
}

model Task {
  id             String             @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  description    String?
  status         TaskStatus         @default(Active)
  organizationId String
  assignedToId   String
  createdById    String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  statusChanges  TaskStatusChange[]
}

model TaskStatusChange {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  taskId          String     @db.ObjectId
  task            Task       @relation(fields: [taskId], references: [id])
  requestedById   String
  requestedStatus TaskStatus
  isApproved      Boolean?
  reviewedById    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}
